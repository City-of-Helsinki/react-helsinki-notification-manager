    "husky": "^9.1.7",
    "i18next": "^24.2.3",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-i18next": "^15.7.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.3"
